{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "out/**"]
		},
		"lint": {
			"dependsOn": ["^build"],
			"cache": true
		},
		"format": {
			"outputs": [],
			"cache": true
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"clean": {
			"cache": false
		}
	}
}
